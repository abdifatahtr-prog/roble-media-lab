    "gray-matter": "^4.0.3",
    "lucide-react": "^0.468.0",
    "marked": "^14.1.4",
    "next": "^15.5.9",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@opennextjs/cloudflare": "^1.20.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.5",
    "eslint-config-next": "^15.5.9",
    "eslint-plugin-jsx-a11y": "^6.10.2",
