  "private": true,
  "scripts": {
    "blog:generate": "node scripts/generate-blog.mjs",
    "predev": "node scripts/generate-blog.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/generate-blog.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
