# ─────────────────────────────────────────────────────────────────────────────
# PUBLIC values (NEXT_PUBLIC_*) are inlined into the browser bundle at BUILD time.
# Put these in `.env.local` for local dev. They are also read during `npm run deploy`
# (which builds locally), so `.env.local` covers production too.
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SITE_URL=https://roblemedialab.co.ke

# WhatsApp Business number, international format, digits only (e.g. 2547XXXXXXXX).
# When set, a floating "Chat on WhatsApp" button appears site-wide.
NEXT_PUBLIC_WHATSAPP=

# Cloudflare Web Analytics beacon token (Dashboard → Analytics & Logs → Web Analytics).
# Privacy-first, cookieless. When set, the analytics beacon loads site-wide.
NEXT_PUBLIC_CF_BEACON_TOKEN=

# Cloudflare Turnstile site key (Dashboard → Turnstile → your widget).
# Public by design. When set, the contact form shows the Turnstile widget.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# GA4 is configured in app/layout.tsx via @next/third-parties (<GoogleAnalytics gaId=… />),
# so no env var is needed. The Measurement ID is public (it ships in the page).

# ─────────────────────────────────────────────────────────────────────────────
# SECRET values are read at RUNTIME on the Cloudflare Worker.
# Local dev: put them in a `.dev.vars` file (gitignored).
# Production: set each as a secret, e.g. `npx wrangler secret put RESEND_API_KEY`
#            (or Cloudflare dashboard → Workers → roble-media-lab → Settings → Variables).
# ─────────────────────────────────────────────────────────────────────────────

# Resend transactional email. Powers the /api/contact notification + confirmation.
# 1. Create a key at resend.com → API Keys.
# 2. Verify the domain roblemedialab.co.ke at resend.com → Domains (add its DNS records).
RESEND_API_KEY=

# Cloudflare Turnstile secret key (pairs with NEXT_PUBLIC_TURNSTILE_SITE_KEY).
# When set, the server verifies each submission's Turnstile token.
TURNSTILE_SECRET_KEY=

# Optional overrides (sensible defaults are used if left blank):
# CONTACT_TO_EMAIL=hello@roblemedialab.co.ke
# CONTACT_FROM_EMAIL=Roble Media Lab <website@roblemedialab.co.ke>
