NEXT_PUBLIC_SITE_URL=https://roblemedialab.co.ke
NEXT_PUBLIC_TALLY_FORM_ID=yPGxE4

# WhatsApp Business number, international format, digits only (e.g. 2547XXXXXXXX).
# When set, a floating "Chat on WhatsApp" button appears site-wide.
NEXT_PUBLIC_WHATSAPP=

# Cloudflare Web Analytics beacon token (Dashboard → Analytics & Logs → Web Analytics).
# Privacy-first, cookieless. When set, the analytics beacon loads site-wide.
NEXT_PUBLIC_CF_BEACON_TOKEN=
